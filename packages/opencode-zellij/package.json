{
  "name": "@auron-labs/opencode-zellij",
  "version": "0.2.0",
  "description": "OpenCode plugin for managing Zellij panes with event subscriptions, output reading, and lifecycle tracking.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun run build && node --test test/*.test.mjs",
    "prepublishOnly": "bun run build"
  },
  "packageManager": "bun@1.2.23",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "opencode",
    "zellij",
    "plugin",
    "terminal",
    "multiplexer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auron-labs/opencode-plugins.git",
    "directory": "packages/opencode-zellij"
  },
  "bugs": {
    "url": "https://github.com/auron-labs/opencode-plugins/issues"
  },
  "homepage": "https://github.com/auron-labs/opencode-plugins/tree/main/packages/opencode-zellij"
}
